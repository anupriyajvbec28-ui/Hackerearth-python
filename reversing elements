import sys
def kadane(arr):
    if not arr:
        return 0
    max_so_far = arr[0]
    current_max = arr[0]
    for i in range(1, len(arr)):
        current_max = max(arr[i], current_max + arr[i])
        max_so_far = max(max_so_far, current_max)
    return max_so_far
def process_queries(N, Q, initial_arr, queries):
    results = []
    for L, R in queries:
        current_arr = list(initial_arr)
        l_idx = L - 1
        r_idx = R - 1
        sub_array = current_arr[l_idx:r_idx+1]
        sub_array.reverse()
        current_arr[l_idx:r_idx+1] = sub_array
        max_sum = kadane(current_arr)
        results.append(max_sum)
        
    return results
def main():
    try:
        line = sys.stdin.readline()
        if not line:
            return
        parts = list(map(int, line.split()))
        if not parts:
            line = sys.stdin.readline()
            if not line:
                return
            parts = list(map(int, line.split()))
        
        if not parts:
            return
        
        N, Q = parts
        line = sys.stdin.readline()
        if not line:
            return
        initial_arr = list(map(int, line.split()))
        queries = []
        for _ in range(Q):
            line = sys.stdin.readline()
            if not line:
                continue
            try:
                l, r = map(int, line.split())
                queries.append((l, r))
            except ValueError:
                continue
        results = process_queries(N, Q, initial_arr, queries)
        for res in results:
            print(res)
            
    except EOFError:
        pass
    except ValueError:
        pass

if __name__ == "__main__":
    main()
