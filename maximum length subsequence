def solve(N, A):
    if N == 0:
        return 0
    A.sort()
    
    max_len = 0
    left = 0
    for right in range(N):
        while A[right] - A[left] > 10:
            left += 1
        current_len = right - left + 1
        if current_len > max_len:
            max_len = current_len
            
    return max_len
N = 10
A = [4, 5, 10, 101, 2, 129, 131, 130, 118, 14]
print(solve(N, A)) 
